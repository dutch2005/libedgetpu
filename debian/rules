#!/usr/bin/make -f
export PYVERS=$(shell py3versions -vr)

%:
	dh $@ --with python3

override_dh_auto_build:
	for py in $(PYVERS); do \
		TF_PYTHON_VERSION=$$py bazel build //pycoral:wheel \
			--distdir=./vendor_deps \
			--nohome_rc --nosystem_rc \
			--cxxopt="-std=c++23" \
			--subcommands \
			--verbose_failures \
			--sandbox_debug \
			-c dbg; \
	done

override_dh_auto_install:
	mkdir -p debian/python3-pycoral/usr/lib/python3/dist-packages/
	for whl in bazel-bin/pycoral/*.whl; do \
		unzip -o $$whl -d debian/python3-pycoral/usr/lib/python3/dist-packages/; \
	done
	rm -rf debian/python3-pycoral/usr/lib/python3/dist-packages/*.dist-info
